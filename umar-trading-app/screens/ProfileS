import React, { useState } from 'react';
import { View, Text, TouchableOpacity, StyleSheet, Switch, Linking } from 'react-native';

export default function ProfileScreen() {
  const [isUrdu, setIsUrdu] = useState(false);

  // JazzCash aur EasyPaisa ka direct intent (Payment App open karne ke liye)
  const openPaymentApp = (app) => {
    if (app === 'JazzCash') {
      Linking.openURL('jazzcash://'); // Agar install hogi toh open hogi
    } else {
      Linking.openURL('easypaisa://');
    }
  };

  return (
    <View style={styles.container}>
      <Text style={styles.title}>{isUrdu ? "ترتیبات" : "Settings"}</Text>
      
      {/* Language Toggle */}
      <View style={styles.row}>
        <Text style={styles.text}>{isUrdu ? "اردو زبان" : "English Language"}</Text>
        <Switch 
          value={isUrdu} 
          onValueChange={(val) => setIsUrdu(val)} 
          trackColor={{ false: '#767577', true: '#81b0ff' }}
        />
      </View>

      {/* Payment Options */}
      <Text style={styles.sectionTitle}>{isUrdu ? "ادائیگی کے طریقے" : "Payment Methods"}</Text>
      
      <TouchableOpacity style={styles.payButton} onPress={() => openPaymentApp('JazzCash')}>
        <Text style={styles.payText}>JazzCash</Text>
      </TouchableOpacity>
      
      <TouchableOpacity style={styles.payButton} onPress={() => openPaymentApp('EasyPaisa')}>
        <Text style={styles.payText}>EasyPaisa</Text>
      </TouchableOpacity>
    </View>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: '#000', padding: 20, paddingTop: 50 },
  title: { color: '#fff', fontSize: 24, fontWeight: 'bold', marginBottom: 20 },
  row: { flexDirection: 'row', justifyContent: 'space-between', marginBottom: 30 },
  text: { color: '#fff', fontSize: 18 },
  sectionTitle: { color: '#aaa', marginBottom: 15, fontSize: 16 },
  payButton: { backgroundColor: '#222', padding: 15, borderRadius: 10, marginBottom: 10 },
  payText: { color: '#fff', textAlign: 'center', fontSize: 16, fontWeight: 'bold' }
});
